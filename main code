<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Uitnodiging</title>

<style>

body{
    margin:0;
    font-family:Arial, sans-serif;
    background:linear-gradient(#87CEEB,#d8f7c5);
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    overflow:hidden;
}

.container{
    position:relative;
    width:420px;
    height:420px;
}

.invitation{
    position:absolute;
    inset:40px;
    background:white;
    border-radius:20px;
    padding:30px;
    text-align:center;
    box-shadow:0 10px 25px rgba(0,0,0,.2);
    opacity:0;
    transition:1s;
    z-index:1;
}

.open .invitation{
    opacity:1;
}

.ladybug{
    position:absolute;
    left:50%;
    top:50%;
    transform:translate(-50%,-50%);
    width:240px;
    height:240px;
    cursor:pointer;
    z-index:5;
}

.head{
    position:absolute;
    width:90px;
    height:90px;
    background:#111;
    border-radius:50%;
    top:-15px;
    left:75px;
}

.body{
    position:absolute;
    width:180px;
    height:180px;
    background:#111;
    border-radius:50%;
    left:30px;
    top:40px;
}

.line{
    position:absolute;
    width:6px;
    height:180px;
    background:#111;
    left:117px;
    top:40px;
    z-index:20;
}
.wing{
    position:absolute;
    width:90px;
    height:170px;
    background:#d91c1c;
    top:45px;
    transition:1s ease;
}

.left{
    left:30px;
    border-radius:90px 0 70px 70px;
    transform-origin:right center;
}

.right{
    left:120px;
    border-radius:0 90px 70px 70px;
    transform-origin:left center;
}

.open .left{
    transform:rotateY(130deg);
}

.open .right{
    transform:rotateY(-130deg);
}

.spot{
    position:absolute;
    width:20px;
    height:20px;
    background:black;
    border-radius:50%;
}

</style>

</head>
<body>

<div class="container">

<div class="invitation">
<h1> Je bent uitgenodigd! </h1>

<h2>Insectenfeestje van Marthe en Paulien</h2>

<p><strong>Datum:</strong> ???</p>

<p><strong>Tijd:</strong> ??? </p>

<p><strong>Locatie:</strong> ??? </p>

<p>Beter dat je er bent xxx</p>

<p>🐞❤️</p>
</div>

<div class="ladybug" onclick="openBug()">

<div class="head"></div>

<div class="body"></div>

<div class="line"></div>

<div class="wing left">

<div class="spot" style="top:25px;left:18px;"></div>
<div class="spot" style="top:70px;left:48px;"></div>
<div class="spot" style="top:120px;left:22px;"></div>

</div>

<div class="wing right">

<div class="spot" style="top:25px;left:52px;"></div>
<div class="spot" style="top:70px;left:18px;"></div>
<div class="spot" style="top:120px;left:48px;"></div>

</div>

</div>

</div>

<script>

function openBug(){
    document.querySelector(".container").classList.toggle("open");
}

</script>

</body>
</html>
